{
  "name": "@inkrypt/inkrypt",
  "version": "0.0.0",
  "description": "Local-first, end-to-end encrypted note-taking app",
  "private": true,
  "license": "AGPL-3.0-only",
  "author": {
    "name": "Peter Bartha",
    "email": "peterbartha@pm.me",
    "url": "https://peterbartha.com/"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "check-types": "turbo run check-types --continue",
    "prepare": "husky"
  },
  "devDependencies": {
    "@biomejs/biome": "2.2.0",
    "husky": "^9.1.7",
    "nano-staged": "^0.8.0",
    "turbo": "^2.5.6"
  },
  "packageManager": "pnpm@10.14.0",
  "engines": {
    "node": ">=22"
  },
  "nano-staged": {
    "*.{js,jsx,ts,tsx,cjs,mjs,json,jsonc,css,html,svelte}": [
      "biome check --write --files-ignore-unknown=true --no-errors-on-unmatched"
    ],
    "*.rs": [
      "rustfmt"
    ]
  }
}
